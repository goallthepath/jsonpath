#!/usr/bin/env python3
"""
jsonpath - Extract values from JSON using simple dot notation.
"""

import json
import sys


def get_value(data, path):
    """Extract value from nested dict using dot notation path."""
    keys = path.split('.')
    current = data
    
    for key in keys:
        if isinstance(current, dict) and key in current:
            current = current[key]
        elif isinstance(current, list) and key.isdigit():
            idx = int(key)
            if 0 <= idx < len(current):
                current = current[idx]
            else:
                return None
        else:
            return None
    
    return current


def main():
    if len(sys.argv) < 2:
        print("Usage: jsonpath <path> [file]", file=sys.stderr)
        print("  jsonpath user.name data.json", file=sys.stderr)
        print("  cat data.json | jsonpath user.name", file=sys.stderr)
        sys.exit(1)
    
    path = sys.argv[1]
    
    # Read from file or stdin
    if len(sys.argv) > 2:
        with open(sys.argv[2]) as f:
            data = json.load(f)
    else:
        data = json.load(sys.stdin)
    
    result = get_value(data, path)
    
    if result is None:
        sys.exit(1)
    
    # Output based on type
    if isinstance(result, (dict, list)):
        print(json.dumps(result, indent=2))
    else:
        print(result)


if __name__ == '__main__':
    main()
